<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Your Blogs</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <%- include('partials/header.ejs'); %>

    <div class="blog-container">
        
        <div class="directory">
        <form action="/blog" method="POST">
            <input type="submit" class="btn btn-secondary my-3" value="New Post">
        </form>
        <% if(locals.blogs){ %>
            <% for(var i = 0; i < blogs.length; i++) { %>
                <button type="button" class="blog-button btn btn-info my-1" data-title="<%= name[i] %>" data-content="<%= blogs[i] %>"><%= name[i] %></button>
            <% } %>
        <% } %>
        </div>

        <div class="blog-content">
            <h1 id="blog-title" style="display: none;"></h1>
            <p id="blog-text" style="display: none;"></p>
            <div id="welcome-message">
                <h1>Welcome to the Blog Website!</h1>
                <p>Select a blog from the left to view its content.</p>
            </div>
        </div>

        <script>
            // Get all blog buttons and add click listeners
            const buttons = document.querySelectorAll('button.blog-button');
            const welcomeMessage = document.getElementById('welcome-message');
            const blogTitle = document.getElementById('blog-title');
            const blogText = document.getElementById('blog-text');

            buttons.forEach(button => {
                button.addEventListener('click', function() {
                    const title = this.dataset.title;
                    const content = this.dataset.content;
                    
                    // Hide welcome message and show blog content
                    welcomeMessage.style.display = 'none';
                    blogTitle.style.display = 'block';
                    blogText.style.display = 'block';
                    
                    // Set blog title and content
                    blogTitle.textContent = title;
                    blogText.textContent = content;
                });
            });
        </script>
    </div>

    <%- include('partials/footer.ejs'); %>
</body>
</html>